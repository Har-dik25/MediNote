# Base URL of your deployed API (FastAPI/Groq/RAG backend), e.g. https://api.medimate.yourdomain.com
# Leave as /api if you configure a Vercel rewrite/proxy to your API host instead.
VITE_API_BASE_URL=/api

# Set to "true" to run the UI entirely against in-memory mock data with no
# backend at all — useful for frontend development/demos before the API exists.
VITE_USE_MOCKS=true

# Local dev only: if set, Vite's dev server proxies /api to this host so
# session cookies work without CORS issues while developing.
VITE_DEV_API_PROXY=
